# Local development (defaults work without this file)
# DEBUG=true
# DATABASE_PATH is unset → back/db.sqlite3

# Production — set these in the Liara console (برنامه → تنظیمات → متغیرهای محیطی)
DEBUG=false
SECRET_KEY=generate-a-long-random-secret-key
DATABASE_PATH=database/db.sqlite3
GUNICORN_CMD_ARGS=--workers 1

# Optional
FRONTEND_URL=https://charity-center.liara.run
ZARINPAL_SANDBOX=false
ZARINPAL_MERCHANT_ID=
ZARINPAL_CALLBACK_URL=https://charity-center.liara.run/api/wallet/topup/callback/
